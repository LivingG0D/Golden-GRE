# Golden GRE — point-to-point tunnel config.
# Copy to /etc/golden-gre/<name>.conf on the server and edit. Start with:
#   systemctl enable --now golden-gre@<name>
#
# IPs below are RFC 5737 documentation placeholders. Replace with real values.

DEV=gre1                    # tunnel device name (unique per host)
LOCAL_PUB=203.0.113.10      # THIS server's public IP
REMOTE_PUB=198.51.100.20    # peer's public IP
TUN_ADDR=10.99.99.1/30      # this end's overlay IP (peer = 10.99.99.2/30)
FOU_PORT=5555               # UDP port for GRE-in-UDP (same on both ends)
MTU=1400                    # tunnel MTU (default 1400)

# --- optional ---
# ROUTES="10.50.0.0/24"            # CIDRs to route via this tunnel
# NAT_SRC="10.99.99.0/30"          # MASQUERADE this source (use node as exit)
# NAT_OUT=eth0                     # egress interface for NAT_SRC
